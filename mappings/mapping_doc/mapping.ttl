@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix sosa: <http://www.w3.org/ns/sosa/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#>.
@prefix gsp: <http://www.opengis.net/ont/geosparql#>.
@prefix qudt: <http://qudt.org/schema/qudt/>.
@prefix unit: <http://qudt.org/vocab/unit/>.
@prefix time: <http://www.w3.org/2006/time#>.
@prefix schema: <http://schema.org/>.
@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente/>.
@prefix edintkos-vars: <http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/>.
@prefix edintkos-foi: <http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/>.
@prefix edintkos-sensortypes: <http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/>.
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix d2rq: <http://www.wiwiss.fu-berlin.de/suhl/bizer/D2RQ/0.1#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix formats: <http://www.w3.org/ns/formats/>.
@prefix comp: <http://semweb.mmlab.be/ns/rml-compression#>.
@prefix void: <http://rdfs.org/ns/void#>.
@prefix fnml: <http://semweb.mmlab.be/ns/fnml#>.
@prefix grel: <http://users.ugent.be/~bjdmeest/function/grel.ttl#>.
@prefix map: <http://mapping.example.com/> .
@base <http://example.com/ns#>.

map:person_000 a foaf:Person ;
	rdfs:label "Jhon Toledo" ;
	foaf:mbox <mailto:ja.toledo@upm.es> .

map:rules_000 schema:contributor map:person_000 ;
	rdf:type schema:Dataset;
    schema:version "1.0.0";
    schema:title "Mappings RML para transformar Mediciones Ambientales a RDF (EDINT Medio Ambiente)";
    schema:dateCreated "30-03-2026";
    schema:description "Este conjunto de mappings RML transforma los datos de mediciones y estaciones medioambientales a RDF, utilizando la ontología EDINT Medio Ambiente y el estándar SOSA/SSN. El objetivo es generar un grafo RDF interoperable para representar plataformas de sensores, sensores ambientales, muestras físicas y observaciones complejas (como calidad del aire, acústica, meteorología y agua), orientado a la gestión sostenible de las entidades locales.".

<sensor_platform_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "mediciones_ambientales.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/estacionDeMedida/{STATION_ID}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant edintmed:SensorPlatform;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant dct:identifier;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "STATION_ID";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdfs:label;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "STATION_NAME_ES";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdfs:comment;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "STATION_DESC_ES";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geo:lat;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "LAT";
			rr:datatype xsd:float
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geo:long;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "LONG";
			rr:datatype xsd:float
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geo:alt;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "ALT";
			rr:datatype xsd:float
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant sosa:hosts;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/sensor/{SENSOR_ID}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gsp:hasGeometry;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/geometria/{STATION_ID}";
			rr:termType rr:IRI
		];
	].


<station_geometry_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "mediciones_ambientales.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/geometria/{STATION_ID}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant rdf:type;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:constant gsp:Geometry;
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant gsp:asWKT;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "POINT ({LONG} {LAT}";
			rr:datatype gsp:wktLiteral
		];
	].


<environmental_sensor_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "mediciones_ambientales.csv";
		rml:referenceFormulation ql:CSV

	];
