	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant sosa:observes;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/{OBS_PROPERTY}";
			rr:termType rr:IRI
		];
	].


