			rml:reference "SENSOR_DESC_ES";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant schema:manufacturer;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "MANUFACTURER";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant sosa:isHostedBy;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/estacionDeMedida/{STATION_ID}";
