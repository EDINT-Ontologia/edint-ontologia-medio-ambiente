<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:gsp="http://www.opengis.net/ont/geosparql#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:qudt="http://qudt.org/schema/qudt/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:sosa="http://www.w3.org/ns/sosa/"
     xmlns:vaem="http://www.linkedmodel.org/schema/vaem#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:dtype="http://www.linkedmodel.org/schema/dtype#"
     xmlns:schema="http://schema.org/"
     xmlns:edintmed="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"
     xmlns:edintkos-foi="http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/"
     xmlns:quantitykind="http://qudt.org/vocab/quantitykind/"
     xmlns:edintkos-vars="http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/"
     xmlns:edintkos-sensortypes="http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/">
        <owl:imports rdf:resource="http://qudt.org/2.1/schema/qudt"/>
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/sosa/"/>
        <dcterms:creator xml:lang="es">Daniel Doña</dcterms:creator>
        <dcterms:creator>Edna Ruckhaus</dcterms:creator>
        <dcterms:creator>Lucía Sánchez</dcterms:creator>
        <dcterms:creator>Maria del Socorro Bernardos</dcterms:creator>
        <dcterms:creator>Oscar Corcho</dcterms:creator>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-18</dcterms:created>
        <dcterms:description xml:lang="en">A lightweight ontology extending SOSA to represent environmental measuring stations and sensors, restricting their observations to the EDINT SKOS controlled vocabulary.</dcterms:description>
        <dcterms:description xml:lang="es">Una ontología ligera que extiende SOSA para representar estaciones de medición y sensores medioambientales, restringiendo sus mediciones al vocabulario controlado SKOS de EDINT.</dcterms:description>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-18</dcterms:issued>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-27</dcterms:modified>
        <dcterms:title xml:lang="en">EDINT Environmental Sensors Ontology</dcterms:title>
        <dcterms:title xml:lang="es">Ontología EDINT de Sensores Medioambientales</dcterms:title>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/manufacturer -->

    <owl:ObjectProperty rdf:about="http://schema.org/manufacturer"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/hasSensorType -->

    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/hasSensorType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalSensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Links an environmental sensor to its type classification.</rdfs:comment>
        <rdfs:comment xml:lang="es">Vincula un sensor medioambiental a su clasificación de tipo.</rdfs:comment>
        <rdfs:label xml:lang="en">has sensor type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de sensor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    


    <!-- http://www.w3.org/ns/sosa/hasFeatureOfInterest -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hasFeatureOfInterest"/>
    


    <!-- http://www.w3.org/ns/sosa/hosts -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/hosts"/>
    


    <!-- http://www.w3.org/ns/sosa/isHostedBy -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/isHostedBy"/>
    


    <!-- http://www.w3.org/ns/sosa/observes -->

    <owl:ObjectProperty rdf:about="http://www.w3.org/ns/sosa/observes"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/Organization -->

    <owl:Class rdf:about="http://schema.org/Organization"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalFeatureOfInterest -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalFeatureOfInterest">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
        <rdfs:label xml:lang="es">Característica de interés de la propiedad medioambiental</rdfs:label>
        <rdfs:label xml:lang="en">Environmental Feature of Interest</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalObservation -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalObservation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Observation"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hasFeatureOfInterest"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/FeaturesOfInterest"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An observation of an environmental property made by an environmental sensor.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una observación de una propiedad medioambiental realizada por un sensor medioambiental.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental observation</rdfs:label>
        <rdfs:label xml:lang="es">Observación medioambiental</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalProperty -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalProperty">
        <rdfs:subClassOf rdf:resource="http://qudt.org/schema/qudt/QuantityKind"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/ObservableProperty"/>
        <rdfs:comment xml:lang="en">A physical, chemical, or acoustic property of the environment that can be observed by sensors.</rdfs:comment>
        <rdfs:comment xml:lang="es">Una propiedad física, química o acústica del medio ambiente que puede ser observada por sensores.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental property</rdfs:label>
        <rdfs:label xml:lang="es">Propiedad medioambiental</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalSensor -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalSensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://schema.org/manufacturer"/>
                <owl:someValuesFrom rdf:resource="http://schema.org/Organization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/isHostedBy"/>
                <owl:someValuesFrom rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/SensorPlatform"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/hasSensorType"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/SensorTypes"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/observes"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/EnvironmentalProperties"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Device designed to observe and measure physical, chemical, or acoustic properties of the environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Dispositivo diseñado para observar y medir propiedades físicas, químicas o acústicas del medio ambiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor medioambiental</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/SensorPlatform -->

    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/SensorPlatform">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
                <owl:someValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hosts"/>
                <owl:someValuesFrom rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/EnvironmentalSensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Physical platform or facility that hosts environmental sensors for monitoring.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plataforma física o instalación que alberga sensores medioambientales para monitorización.</rdfs:comment>
        <rdfs:label xml:lang="es">Plataforma de sensor</rdfs:label>
        <rdfs:label xml:lang="en">Sensor platform</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry"/>
    


    <!-- http://www.w3.org/ns/sosa/FeatureOfInterest -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/FeatureOfInterest"/>
    


    <!-- http://www.w3.org/ns/sosa/ObservableProperty -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/ObservableProperty"/>
    


    <!-- http://www.w3.org/ns/sosa/Observation -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Observation"/>
    


    <!-- http://www.w3.org/ns/sosa/Platform -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Platform"/>
    


    <!-- http://www.w3.org/ns/sosa/Sensor -->

    <owl:Class rdf:about="http://www.w3.org/ns/sosa/Sensor"/>
    


