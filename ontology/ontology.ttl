@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente/> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .

# ---------------------------------------------------------------------------
# ONTOLOGY
# ---------------------------------------------------------------------------
edintmed: a owl:Ontology ;
    dct:title "Ontología EDINT de Sensores Medioambientales"@es ;
    dct:title "EDINT Environmental Sensors Ontology"@en ;
    dct:description "Una ontología ligera que extiende SOSA para representar estaciones de medición y sensores medioambientales, restringiendo sus mediciones al vocabulario controlado SKOS de EDINT."@es ;
    dct:description "A lightweight ontology extending SOSA to represent environmental measuring stations and sensors, restricting their observations to the EDINT SKOS controlled vocabulary."@en ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:modified "2026-03-18"^^xsd:date ;
    dct:creator "Daniel Doña"@es ,
                "Edna Ruckhaus" ,
                "Lucía Sánchez" ,
                "Maria del Socorro Bernardos" ,
                "Oscar Corcho" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "0.1.0" ;
    owl:imports <http://www.w3.org/ns/sosa/> ,
                <http://www.opengis.net/ont/geosparql#> .

# ---------------------------------------------------------------------------
# CLASSES
# ---------------------------------------------------------------------------

### Estación de Medición
edintmed:MeasuringStation a owl:Class ;
    rdfs:subClassOf sosa:Platform ;
    rdfs:subClassOf geo:Feature ;
    rdfs:label "Estación de medición medioambiental"@es ;
    rdfs:label "Environmental measuring station"@en ;
    rdfs:comment "Plataforma física o instalación (ej. cabina de calidad del aire, boya acuática, torre meteorológica) que alberga sensores para la monitorización del medio ambiente."@es ;
    rdfs:comment "Physical platform or facility (e.g., air quality cabin, water buoy, meteorological tower) that hosts sensors for environmental monitoring."@en ;
    
    # Restricción: Una estación alberga (sosa:hosts) sensores medioambientales
    rdfs:subClassOf[
        a owl:Restriction ;
        owl:onProperty sosa:hosts ;
        owl:someValuesFrom edintmed:Sensor
    ] ;
    
    # Restricción: Una estación tiene una localización espacial/geometría
    rdfs:subClassOf[
        a owl:Restriction ;
        owl:onProperty geo:hasGeometry ;
        owl:someValuesFrom geo:Geometry
    ] .

### Sensor
edintmed:Sensor a owl:Class ;
    rdfs:subClassOf sosa:Sensor ;
    rdfs:label "Sensor medioambiental"@es ;
    rdfs:label "Environmental sensor"@en ;
    rdfs:comment "Dispositivo diseñado para observar y medir propiedades físicas, químicas o acústicas del medio ambiente."@es ;
    rdfs:comment "Device designed to observe and measure physical, chemical, or acoustic properties of the environment."@en ;
    
    # Sensores siempre en una estación (por confirmar)
    rdfs:subClassOf[
        a owl:Restriction ;
        owl:onProperty sosa:isHostedBy ;
        owl:someValuesFrom edintmed:MeasuringStation
    ] ;

    # Propiedades del SKOS definido solo
    rdfs:subClassOf[
        a owl:Restriction ;
        owl:onProperty sosa:observes ;
        owl:allValuesFrom[
            a owl:Restriction ;
            owl:onProperty skos:inScheme ;
            owl:hasValue edintkos:SensorVariables
        ]
    ] .