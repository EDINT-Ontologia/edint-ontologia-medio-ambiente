  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "A lightweight ontology extending SOSA to represent environmental measuring stations and sensors, restricting their observations to the EDINT SKOS controlled vocabulary."
  }, {
    "@language" : "es",
    "@value" : "Una ontología ligera que extiende SOSA para representar estaciones de medición y sensores medioambientales, restringiendo sus mediciones al vocabulario controlado SKOS de EDINT."
  } ],
