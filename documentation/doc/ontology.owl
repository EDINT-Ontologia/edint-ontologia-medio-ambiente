    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/MeasuringStation -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/MeasuringStation">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Platform"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
                <owl:someValuesFrom rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/hosts"/>
                <owl:someValuesFrom rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/Sensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Physical platform or facility (e.g., air quality cabin, water buoy, meteorological tower) that hosts sensors for environmental monitoring.</rdfs:comment>
        <rdfs:comment xml:lang="es">Plataforma física o instalación (ej. cabina de calidad del aire, boya acuática, torre meteorológica) que alberga sensores para la monitorización del medio ambiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental measuring station</rdfs:label>
        <rdfs:label xml:lang="es">Estación de medición medioambiental</rdfs:label>
    </owl:Class>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/medioambiente/Sensor -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/Sensor">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/sosa/Sensor"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/isHostedBy"/>
                <owl:someValuesFrom rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/MeasuringStation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.w3.org/ns/sosa/observes"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/SensorVariables"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Device designed to observe and measure physical, chemical, or acoustic properties of the environment.</rdfs:comment>
        <rdfs:comment xml:lang="es">Dispositivo diseñado para observar y medir propiedades físicas, químicas o acústicas del medio ambiente.</rdfs:comment>
        <rdfs:label xml:lang="en">Environmental sensor</rdfs:label>
        <rdfs:label xml:lang="es">Sensor medioambiental</rdfs:label>
    </owl:Class>
    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->


    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry"/>
    


