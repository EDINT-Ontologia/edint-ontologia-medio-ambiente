    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/FeaturesOfInterest -->


    <owl:NamedIndividual rdf:about="http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/FeaturesOfInterest"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/SensorTypes -->


    <owl:NamedIndividual rdf:about="http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/SensorTypes"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/SensorVariables -->


    <owl:NamedIndividual rdf:about="http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/SensorVariables"/>
