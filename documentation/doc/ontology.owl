<?xml version="1.0"?>
<rdf:RDF xmlns="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"
     xml:base="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:schema="http://schema.org/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/medioambiente/">
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/sosa/"/>
        <terms:creator xml:lang="es">Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Maria del Socorro Bernardos</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:description xml:lang="en">A lightweight ontology extending SOSA to represent environmental measuring stations and sensors, restricting their observations to the EDINT SKOS controlled vocabulary.</terms:description>
        <terms:description xml:lang="es">Una ontología ligera que extiende SOSA para representar estaciones de medición y sensores medioambientales, restringiendo sus mediciones al vocabulario controlado SKOS de EDINT.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-18</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-18</terms:modified>
        <terms:title xml:lang="en">EDINT Environmental Sensors Ontology</terms:title>
        <terms:title xml:lang="es">Ontología EDINT de Sensores Medioambientales</terms:title>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


