@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix gsp: <http://www.opengis.net/ont/geosparql#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix schema: <http://schema.org/> .

@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente/> .
@prefix edintkos-vars: <http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/> .
@prefix edintkos-foi: <http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/> .
@prefix edintkos-sensortypes: <http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/> .
@prefix ex: <http://example.org/> .

# ---------------------------------------------------------------------------
# ESTACIÓN DE MUESTREO
# ---------------------------------------------------------------------------

ex:Station_Sampling_Malaga_001 a edintmed:SensorPlatform ;
    rdfs:label "Estación de muestreo de agua - Málaga Centro"@es ;
    rdfs:label "Water sampling station - Málaga Centro"@en ;
    dct:identifier "WSS-MAL-001" ;
    geo:lat "36.7213"^^xsd:float ;
    geo:long "-4.4214"^^xsd:float ;
    rdfs:comment "Estación fija para recolección de muestras de agua potable"@es ;
    rdfs:comment "Fixed station for collecting drinking water samples"@en ;
    gsp:hasGeometry [
        a gsp:Geometry ;
        gsp:asWKT "POINT(-4.4214 36.7213)"^^xsd:string .
    ] ;
    sosa:hosts ex:Sensor_SampleAnalyzer_001 .

# ---------------------------------------------------------------------------
# SENSOR
# ---------------------------------------------------------------------------

ex:Sensor_SampleAnalyzer_001 a edintmed:EnvironmentalSensor ;
    rdfs:label "Analizador de agua potable - Multi-parámetro"@es ;
    rdfs:label "Drinking water analyzer - Multi-parameter"@en ;
    dct:identifier "WSA-001-MULTI" ;
    rdfs:comment "Analizador de laboratorio para análisis de agua potable"@es ;
    rdfs:comment "Lab analyzer for drinking water analysis"@en ;
    schema:manufacturer ex:Manufacturer_Multiparametro ;
    edintmed:hasSensorType edintkos-sensortypes:AirQualitySensor ;
    sosa:isHostedBy ex:Station_Sampling_Malaga_001 ;
    sosa:observes edintkos-vars:WaterPH ,
                  edintkos-vars:DissolvedOxygen ,
                  edintkos-vars:WaterTurbidity ,
                  edintkos-vars:WaterTemperature ,
                  edintkos-vars:Conductivity .

# ---------------------------------------------------------------------------
# MUESTRA 1: 18/03/2026
# ---------------------------------------------------------------------------

ex:Sample_Water_Malaga_001_20260318 a sosa:Sample ;
    rdfs:label "Muestra de agua potable - Málaga Centro - 18/03/2026 09:00"@es ;
    rdfs:label "Drinking water sample - Málaga Centro - 18/03/2026 09:00"@en ;
    dct:identifier "WS-MAL-001-20260318-0900" ;
    sosa:isSampleOf edintkos-foi:DrinkingWater .

# ---------------------------------------------------------------------------
# MUESTRA 2: 19/03/2026
# ---------------------------------------------------------------------------

ex:Sample_Water_Malaga_001_20260319 a sosa:Sample ;
    rdfs:label "Muestra de agua potable - Málaga Centro - 19/03/2026 09:00"@es ;
    rdfs:label "Drinking water sample - Málaga Centro - 19/03/2026 09:00"@en ;
    dct:identifier "WS-MAL-001-20260319-0900" ;
    sosa:isSampleOf edintkos-foi:DrinkingWater .

# ---------------------------------------------------------------------------
# OBSERVACIONES - MUESTRA 1 (18/03/2026)
# ---------------------------------------------------------------------------

# Medición pH
ex:Observation_Sample1_PH a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de pH - Muestra agua 18/03/2026"@es ;
    rdfs:label "pH measurement - Water sample 18/03/2026"@en ;
    sosa:madeBySensor ex:Sensor_SampleAnalyzer_001 ;
    sosa:observedProperty edintkos-vars:WaterPH ;
    sosa:hasFeatureOfInterest ex:Sample_Water_Malaga_001_20260318 ;
    sosa:resultTime "2026-03-18T09:30:00+01:00"^^xsd:dateTime ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "7.82"^^xsd:decimal ;
        qudt:unit unit:PH
    ] .

# Medición oxígeno disuelto
ex:Observation_Sample1_DO a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de oxígeno disuelto - Muestra agua 18/03/2026"@es ;
    rdfs:label "Dissolved oxygen measurement - Water sample 18/03/2026"@en ;
    sosa:madeBySensor ex:Sensor_SampleAnalyzer_001 ;
    sosa:observedProperty edintkos-vars:DissolvedOxygen ;
    sosa:hasFeatureOfInterest ex:Sample_Water_Malaga_001_20260318 ;
    sosa:resultTime "2026-03-18T09:30:00+01:00"^^xsd:dateTime ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "8.5"^^xsd:decimal ;
        qudt:unit unit:MilliGM-PER-L
    ] .

# Medición turbidez
ex:Observation_Sample1_Turbidity a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de turbidez - Muestra agua 18/03/2026"@es ;
    rdfs:label "Turbidity measurement - Water sample 18/03/2026"@en ;
    sosa:madeBySensor ex:Sensor_SampleAnalyzer_001 ;
    sosa:observedProperty edintkos-vars:WaterTurbidity ;
    sosa:hasFeatureOfInterest ex:Sample_Water_Malaga_001_20260318 ;
    sosa:resultTime "2026-03-18T09:30:00+01:00"^^xsd:dateTime ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "4.2"^^xsd:decimal ;
        qudt:unit unit:NTU
    ] .

# Medición temperatura agua
ex:Observation_Sample1_Temp a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de temperatura del agua - Muestra 18/03/2026"@es ;
    rdfs:label "Water temperature measurement - Sample 18/03/2026"@en ;
    sosa:madeBySensor ex:Sensor_SampleAnalyzer_001 ;
    sosa:observedProperty edintkos-vars:WaterTemperature ;
    sosa:hasFeatureOfInterest ex:Sample_Water_Malaga_001_20260318 ;
    sosa:resultTime "2026-03-18T09:30:00+01:00"^^xsd:dateTime ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "16.3"^^xsd:decimal ;
        qudt:unit unit:DEG_C
    ] .

# Medición conductividad
ex:Observation_Sample1_Conductivity a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de conductividad - Muestra agua 18/03/2026"@es ;
    rdfs:label "Conductivity measurement - Water sample 18/03/2026"@en ;
    sosa:madeBySensor ex:Sensor_SampleAnalyzer_001 ;
    sosa:observedProperty edintkos-vars:Conductivity ;
    sosa:hasFeatureOfInterest ex:Sample_Water_Malaga_001_20260318 ;
    sosa:resultTime "2026-03-18T09:30:00+01:00"^^xsd:dateTime ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "485.0"^^xsd:decimal ;
        qudt:unit unit:MicroS-PER-CentiM
    ] .

