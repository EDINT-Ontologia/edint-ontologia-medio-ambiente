# ---------------------------------------------------------------------------
# MANUFACTURERS
# ---------------------------------------------------------------------------

ex:Manufacturer_Sonometer a schema:Organization ;
    rdfs:label "Sonometer Technologies"@en ;
    rdfs:label "Tecnologías Sonómetro"@es .

ex:Manufacturer_Integrador a schema:Organization ;
    rdfs:label "Acoustic Integrators Ltd."@en ;
    rdfs:label "Integradores Acústicos S.L."@es .

