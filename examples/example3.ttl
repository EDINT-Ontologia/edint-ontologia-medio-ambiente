# ---------------------------------------------------------------------------
# MANUFACTURERS
# ---------------------------------------------------------------------------

ex:Manufacturer_PT1000 a schema:Organization ;
    rdfs:label "PT1000 Sensors Corp."@en ;
    rdfs:label "Sensores PT1000 S.A."@es .

ex:Manufacturer_Electrodo a schema:Organization ;
    rdfs:label "Electrode Systems Ltd."@en ;
    rdfs:label "Sistemas de Electrodo S.L."@es .

ex:Manufacturer_Optica a schema:Organization ;
    rdfs:label "Optical Fluorescence Inc."@en ;
    rdfs:label "Fluorescencia Óptica S.A."@es .

ex:Manufacturer_Nefelometro a schema:Organization ;
    rdfs:label "Nephelometer Technologies"@en ;
    rdfs:label "Tecnologías Nefelómetro"@es .

ex:Manufacturer_Amperometrico a schema:Organization ;
    rdfs:label "Amperometric Instruments"@en ;
    rdfs:label "Instrumentos Amperométricos S.L."@es .

