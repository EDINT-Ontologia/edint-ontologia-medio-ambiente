@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix gsp: <http://www.opengis.net/ont/geosparql#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix schema: <http://schema.org/> .

@prefix edintmed: <http://vocab.linkeddata.es/datosabiertos/def/medioambiente/> .
@prefix edintkos-vars: <http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/> .
@prefix edintkos-foi: <http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/> .
@prefix edintkos-sensortypes: <http://vocab.linkeddata.es/datosabiertos/kos/edint/sensortypes/> .
@prefix ex: <http://example.org/> .

# ---------------------------------------------------------------------------
# ESTACION METEOROLOGICA
# ---------------------------------------------------------------------------

ex:Station_Met_001 a edintmed:SensorPlatform ;
    rdfs:label "Estación meteorológica automática - Parque del Retiro"@es ;
    rdfs:label "Automatic weather station - Retiro Park"@en ;
    dct:identifier "MET-001-MAD" ;
    geo:lat "40.4153"^^xsd:float ;
    geo:long "-3.6845"^^xsd:float ;
    geo:alt "609"^^xsd:float ;
    rdfs:comment "Estación meteorológica automática para monitorización de parámetros climáticos"@es ;
    rdfs:comment "Automatic weather station for climate parameters monitoring"@en ;
    gsp:hasGeometry [
        a gsp:Geometry ;
        gsp:asWKT "POINT(-3.6845 40.4153)"^^xsd:string .
    ] ;

    # estaciones aloja sensores
    sosa:hosts ex:Sensor_Wind_001 ;
    sosa:hosts ex:Sensor_Rain_001 ;
    sosa:hosts ex:Sensor_Radiation_001 ;
    sosa:hosts ex:Sensor_Humidity_001 .

# ---------------------------------------------------------------------------
# SENSORS
# ---------------------------------------------------------------------------

ex:Sensor_Wind_001 a edintmed:EnvironmentalSensor ;
    rdfs:label "Sensor de viento - Anemómetro y veleta"@es ;
    rdfs:label "Wind sensor - Anemometer and wind vane"@en ;
    dct:identifier "WIND-001-AUTO" ;
    schema:manufacturer ex:Manufacturer_Anemometro ;
    edintmed:hasSensorType edintkos-sensortypes:ClimaticSensor ;
    sosa:isHostedBy ex:Station_Met_001 ;
    sosa:observes edintkos-vars:WindSpeed ,
                  edintkos-vars:MaximumWindSpeed ,
                  edintkos-vars:WindDirection .

ex:Sensor_Rain_001 a edintmed:EnvironmentalSensor ;
    rdfs:label "Sensor de precipitación - Pluviómetro"@es ;
    rdfs:label "Precipitation sensor - Rain gauge"@en ;
    dct:identifier "RAIN-001-GAUGE" ;
    schema:manufacturer ex:Manufacturer_Pluviormetro ;
    edintmed:hasSensorType edintkos-sensortypes:ClimaticSensor ;
    sosa:isHostedBy ex:Station_Met_001 ;
    sosa:observes edintkos-vars:PrecipitationAmount ,
                  edintkos-vars:PrecipitationIntensity .

ex:Sensor_Radiation_001 a edintmed:EnvironmentalSensor ;
    rdfs:label "Sensor de radiación solar - Piranómetro"@es ;
    rdfs:label "Solar radiation sensor - Pyranometer"@en ;
    dct:identifier "RAD-001-PYRANO" ;
    schema:manufacturer ex:Manufacturer_Piranometro ;
    edintmed:hasSensorType edintkos-sensortypes:ClimaticSensor ;
    sosa:isHostedBy ex:Station_Met_001 ;
    sosa:observes edintkos-vars:SolarIrradiance ,
                  edintkos-vars:UVIndex .

ex:Sensor_Humidity_001 a edintmed:EnvironmentalSensor ;
    rdfs:label "Sensor de humedad relativa - Capacitivo"@es ;
    rdfs:label "Relative humidity sensor - Capacitive"@en ;
    dct:identifier "HUM-001-CAP" ;
    schema:manufacturer ex:Manufacturer_Capacitivo ;
    edintmed:hasSensorType edintkos-sensortypes:ClimaticSensor ;
    sosa:isHostedBy ex:Station_Met_001 ;
    sosa:observes edintkos-vars:RelativeHumidity .

# ---------------------------------------------------------------------------
# OBSERVACIONES - 18/03/2026
# ---------------------------------------------------------------------------

# Medición velocidad viento mañana
ex:Observation_WindSpeed_001_Morning a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de velocidad del viento - 18/03/2026 09:00"@es ;
    rdfs:label "Wind speed measurement - 18/03/2026 09:00"@en ;
    sosa:madeBySensor ex:Sensor_Wind_001 ;
    sosa:observedProperty edintkos-vars:WindSpeed ;
    sosa:hasFeatureOfInterest edintkos-foi:Wind ;
    sosa:resultTime "2026-03-18T09:00:00+01:00"^^xsd:dateTime ;
    sosa:phenomenonTime [
        a time:InstantaneousEvent ;
        time:inXSDTimeInterval [
            a time:TimePeriod ;
            time:hasBeginning [
                a time:Instant ;
                time:inXSDDateTime "2026-03-18T08:50:00+01:00"^^xsd:dateTime
            ] ;
            time:hasEnd [
                a time:Instant ;
                time:inXSDDateTime "2026-03-18T09:00:00+01:00"^^xsd:dateTime
            ]
        ]
    ] ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "4.2"^^xsd:decimal ;
        qudt:unit unit:M-PER-SEC
    ] .

# Medición velocidad viento tarde
ex:Observation_WindSpeed_001_Evening a edintmed:EnvironmentalObservation ;
    rdfs:label "Medición de velocidad del viento - 18/03/2026 17:00"@es ;
    rdfs:label "Wind speed measurement - 18/03/2026 17:00"@en ;
    sosa:madeBySensor ex:Sensor_Wind_001 ;
    sosa:observedProperty edintkos-vars:WindSpeed ;
    sosa:hasFeatureOfInterest edintkos-foi:Wind ;
    sosa:resultTime "2026-03-18T17:00:00+01:00"^^xsd:dateTime ;
    sosa:phenomenonTime [
        a time:InstantaneousEvent ;
        time:inXSDTimeInterval [
            a time:TimePeriod ;
            time:hasBeginning [
                a time:Instant ;
                time:inXSDDateTime "2026-03-18T16:50:00+01:00"^^xsd:dateTime
            ] ;
            time:hasEnd [
                a time:Instant ;
                time:inXSDDateTime "2026-03-18T17:00:00+01:00"^^xsd:dateTime
            ]
        ]
    ] ;
    sosa:hasResult [
        a qudt:QuantityValue ;
        qudt:numericValue "6.8"^^xsd:decimal ;
        qudt:unit unit:M-PER-SEC
    ] .

