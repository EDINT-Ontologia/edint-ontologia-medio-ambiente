    rdfs:label "Pyranometer Instruments Ltd."@en ;
    rdfs:label "Instrumentos Piranómetro S.L."@es .

ex:Manufacturer_Capacitivo a schema:Organization ;
    rdfs:label "Capacitive Sensors Inc."@en ;
    rdfs:label "Sensores Capacitivos S.A."@es .

