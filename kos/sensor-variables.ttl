@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix edintkos-vars: <http://vocab.linkeddata.es/datosabiertos/kos/edint/variables/> .
@prefix edintkos-foi: <http://vocab.linkeddata.es/datosabiertos/kos/edint/foi/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---------------------------------------------------------------------------
# ESQUEMA PRINCIPAL (Concept Scheme)
# ---------------------------------------------------------------------------
edintkos-vars:SensorVariables a skos:ConceptScheme ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:modified "2026-03-18"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Sensor variables"@en ;
    rdfs:label "Variables de sensor"@es ;
    dct:title "Concept scheme grouping properties and magnitudes measured by sensors in urban environments"@en ;
    dct:title "Esquema de conceptos agrupando magnitudes medidas por sensores en entornos urbanos"@es ;
    skos:note "Hierarchical vocabulary of physical, chemical, and acoustic properties observable by sensors and their associated QUDT units."@en ;
    skos:note "Vocabulario jerárquico de las diferentes magnitudes o propiedades físicas, químicas y acústicas observables mediante sensores y sus unidades QUDT asociadas."@es ;
    skos:hasTopConcept edintkos-vars:MeteorologicalVariables ;
    skos:hasTopConcept edintkos-vars:AirQualityVariables ;
    skos:hasTopConcept edintkos-vars:AcousticVariables ;
    skos:hasTopConcept edintkos-vars:WaterQualityVariables ;
    skos:hasTopConcept edintkos-vars:SoilVariables ;
    skos:hasTopConcept edintkos-vars:TrafficVariables ;
    skos:hasTopConcept edintkos-vars:EnergyVariables ;
    skos:hasTopConcept edintkos-vars:WasteVariables ;
    skos:hasTopConcept edintkos-vars:SensorStatusVariables .

# ---------------------------------------------------------------------------
# CATEGORÍAS PRINCIPALES (Top Concepts)
# ---------------------------------------------------------------------------

edintkos-vars:MeteorologicalVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Meteorological variables"@en ;
    skos:prefLabel "Variables meteorológicas"@es ;
    skos:definition "Variables related to weather and atmospheric conditions."@en ;
    skos:definition "Variables relacionadas con el tiempo y las condiciones atmosféricas."@es ;
    skos:narrower edintkos-vars:TemperatureVariables ;
    skos:narrower edintkos-vars:HumidityVariables ;
    skos:narrower edintkos-vars:PressureVariables ;
    skos:narrower edintkos-vars:WindVariables ;
    skos:narrower edintkos-vars:PrecipitationVariables ;
    skos:narrower edintkos-vars:RadiationVariables ;
    skos:narrower edintkos-vars:LightVariables ;
    skos:narrower edintkos-vars:VisibilityVariables .

edintkos-vars:AirQualityVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Air quality variables"@en ;
    skos:prefLabel "Variables de calidad del aire"@es ;
    skos:definition "Variables related to air pollution and atmospheric composition."@en ;
    skos:definition "Variables relacionadas con la contaminación del aire y la composición atmosférica."@es ;
    skos:narrower edintkos-vars:GaseousPollutants ;
    skos:narrower edintkos-vars:GreenhouseGases ;
    skos:narrower edintkos-vars:ParticulateMatterVariables ;
    skos:narrower edintkos-vars:VolatileOrganicCompounds ;
    skos:narrower edintkos-vars:HeavyMetalVariables ;
    skos:narrower edintkos-vars:PollenVariables ;
    skos:narrower edintkos-vars:OdorVariables .

edintkos-vars:AcousticVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Acoustic variables"@en ;
    skos:prefLabel "Variables acústicas"@es ;
    skos:definition "Variables related to sound and noise measurements."@en ;
    skos:definition "Variables relacionadas con mediciones de sonido y ruido."@es ;
    skos:narrower edintkos-vars:EquivalentSoundPressureLevel ;
    skos:narrower edintkos-vars:StatisticalNoiseLevels ;
    skos:narrower edintkos-vars:TemporalNoiseLevels .

edintkos-vars:WaterQualityVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Water quality variables"@en ;
    skos:prefLabel "Variables de calidad del agua"@es ;
    skos:definition "Variables related to water quality and hydraulic monitoring."@en ;
    skos:definition "Variables relacionadas con la calidad del agua y la monitorización hidráulica."@es ;
    skos:narrower edintkos-vars:WaterPhysicochemicalVariables ;
    skos:narrower edintkos-vars:WaterHydraulicVariables ;
    skos:narrower edintkos-vars:WaterNutrientVariables ;
    skos:narrower edintkos-vars:WaterBiologicalVariables .

edintkos-vars:SoilVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Soil variables"@en ;
    skos:prefLabel "Variables del suelo"@es ;
    skos:definition "Variables related to soil properties and conditions."@en ;
    skos:definition "Variables relacionadas con las propiedades y condiciones del suelo."@es ;
    skos:narrower edintkos-vars:SoilTemperature ;
    skos:narrower edintkos-vars:SoilMoistureTension ;
    skos:narrower edintkos-vars:SoilMoistureContent ;
    skos:narrower edintkos-vars:SoilPH ;
    skos:narrower edintkos-vars:SoilElectricalConductivity ;
    skos:narrower edintkos-vars:SoilSalinity .

edintkos-vars:TrafficVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Traffic variables"@en ;
    skos:prefLabel "Variables de tráfico"@es ;
    skos:definition "Variables related to traffic flow and vehicle monitoring."@en ;
    skos:definition "Variables relacionadas con el flujo de tráfico y la monitorización de vehículos."@es ;
    skos:narrower edintkos-vars:TrafficFlowVariables ;
    skos:narrower edintkos-vars:TrafficSpeedVariables ;
    skos:narrower edintkos-vars:TrafficOccupancyVariables .

edintkos-vars:EnergyVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Energy variables"@en ;
    skos:prefLabel "Variables energéticas"@es ;
    skos:definition "Variables related to energy consumption and generation."@en ;
    skos:definition "Variables relacionadas con el consumo y la generación de energía."@es ;
    skos:narrower edintkos-vars:ElectricityVariables ;
    skos:narrower edintkos-vars:GasVariables .

edintkos-vars:WasteVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Waste management variables"@en ;
    skos:prefLabel "Variables de gestión de residuos"@es ;
    skos:definition "Variables related to waste collection and container monitoring."@en ;
    skos:definition "Variables relacionadas con la recogida de residuos y la monitorización de contenedores."@es ;
    skos:narrower edintkos-vars:ContainerFillLevel ;
    skos:narrower edintkos-vars:ContainerTemperature ;
    skos:narrower edintkos-vars:ContainerWeight .

edintkos-vars:SensorStatusVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Sensor status variables"@en ;
    skos:prefLabel "Variables de estado del sensor"@es ;
    skos:definition "Variables related to the operational status of sensor devices."@en ;
    skos:definition "Variables relacionadas con el estado operativo de los dispositivos sensores."@es ;
    skos:narrower edintkos-vars:BatteryLevel ;
    skos:narrower edintkos-vars:BatteryVoltage ;
    skos:narrower edintkos-vars:InternalSensorTemperature ;
    skos:narrower edintkos-vars:SignalStrength ;
    skos:narrower edintkos-vars:SensorUptime .

# ===========================================================================
# METEOROLOGICAL VARIABLES
# ===========================================================================

# ---------------------------------------------------------------------------
# Temperature Variables
# ---------------------------------------------------------------------------

edintkos-vars:TemperatureVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Temperature variables"@en ;
    skos:prefLabel "Variables de temperatura"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:AirTemperature ;
    skos:narrower edintkos-vars:RoadTemperature ;
    skos:narrower edintkos-vars:DewPointTemperature ;
    skos:narrower edintkos-vars:WetBulbTemperature ;
    skos:narrower edintkos-vars:HeatIndex ;
    skos:narrower edintkos-vars:WindChill .

edintkos-vars:AirTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Air temperature"@en ;
    skos:prefLabel "Temperatura del aire"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos-vars:RoadTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Road surface temperature"@en ;
    skos:prefLabel "Temperatura de la calzada"@es ;
    skos:altLabel "Asphalt temperature"@en ;
    skos:altLabel "Temperatura del asfalto"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos-vars:DewPointTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Dew point temperature"@en ;
    skos:prefLabel "Temperatura de punto de rocío"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos-vars:WetBulbTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Wet bulb temperature"@en ;
    skos:prefLabel "Temperatura de bulbo húmedo"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos-vars:HeatIndex a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Heat index"@en ;
    skos:prefLabel "Índice de calor"@es ;
    skos:altLabel "Apparent temperature"@en ;
    skos:altLabel "Temperatura aparente"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos-vars:WindChill a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:TemperatureVariables ;
    skos:prefLabel "Wind chill"@en ;
    skos:prefLabel "Sensación térmica por viento"@es ;
    qudt:applicableUnit unit:DEG_C .

# ---------------------------------------------------------------------------
# Humidity Variables
# ---------------------------------------------------------------------------

edintkos-vars:HumidityVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Humidity variables"@en ;
    skos:prefLabel "Variables de humedad"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:RelativeHumidity ;
    skos:narrower edintkos-vars:AbsoluteHumidity .

edintkos-vars:RelativeHumidity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:HumidityVariables ;
    skos:prefLabel "Relative humidity"@en ;
    skos:prefLabel "Humedad relativa"@es ;
    qudt:applicableUnit unit:PERCENT .

edintkos-vars:AbsoluteHumidity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:HumidityVariables ;
    skos:prefLabel "Absolute humidity"@en ;
    skos:prefLabel "Humedad absoluta"@es ;
    qudt:applicableUnit unit:GM-PER-M3 .

# ---------------------------------------------------------------------------
# Pressure Variables
# ---------------------------------------------------------------------------

edintkos-vars:PressureVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Pressure variables"@en ;
    skos:prefLabel "Variables de presión"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:AtmosphericPressure ;
    skos:narrower edintkos-vars:SeaLevelPressure .

edintkos-vars:AtmosphericPressure a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PressureVariables ;
    skos:prefLabel "Atmospheric pressure"@en ;
    skos:prefLabel "Presión atmosférica"@es ;
    qudt:applicableUnit unit:HectoPA .

edintkos-vars:SeaLevelPressure a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PressureVariables ;
    skos:prefLabel "Sea level pressure"@en ;
    skos:prefLabel "Presión a nivel del mar"@es ;
    qudt:applicableUnit unit:HectoPA .

# ---------------------------------------------------------------------------
# Wind Variables
# ---------------------------------------------------------------------------

edintkos-vars:WindVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Wind variables"@en ;
    skos:prefLabel "Variables de viento"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:WindSpeed ;
    skos:narrower edintkos-vars:MaximumWindSpeed ;
    skos:narrower edintkos-vars:WindDirection ;
    skos:narrower edintkos-vars:WindGustDirection .

edintkos-vars:WindSpeed a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:WindVariables ;
    skos:prefLabel "Wind speed"@en ;
    skos:prefLabel "Velocidad del viento"@es ;
    qudt:applicableUnit unit:M-PER-SEC .

edintkos-vars:MaximumWindSpeed a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:WindVariables ;
    skos:prefLabel "Maximum wind speed"@en ;
    skos:prefLabel "Velocidad máxima del viento"@es ;
    skos:altLabel "Wind gust speed"@en ;
    skos:altLabel "Racha de viento"@es ;
    qudt:applicableUnit unit:M-PER-SEC .

edintkos-vars:WindDirection a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:WindVariables ;
    skos:prefLabel "Wind direction"@en ;
    skos:prefLabel "Dirección del viento"@es ;
    qudt:applicableUnit unit:DEG .

edintkos-vars:WindGustDirection a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:WindVariables ;
    skos:prefLabel "Wind gust direction"@en ;
    skos:prefLabel "Dirección de la racha de viento"@es ;
    qudt:applicableUnit unit:DEG .

# ---------------------------------------------------------------------------
# Precipitation Variables
# ---------------------------------------------------------------------------

edintkos-vars:PrecipitationVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Precipitation variables"@en ;
    skos:prefLabel "Variables de precipitación"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:PrecipitationAmount ;
    skos:narrower edintkos-vars:PrecipitationIntensity ;
    skos:narrower edintkos-vars:SnowDepth ;
    skos:narrower edintkos-vars:SnowWaterEquivalent .

edintkos-vars:PrecipitationAmount a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PrecipitationVariables ;
    skos:prefLabel "Precipitation amount"@en ;
    skos:prefLabel "Cantidad de precipitación"@es ;
    skos:altLabel "Rainfall"@en ;
    skos:altLabel "Lluvia"@es ;
    qudt:applicableUnit unit:MilliM , unit:L-PER-M2 .

edintkos-vars:PrecipitationIntensity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PrecipitationVariables ;
    skos:prefLabel "Precipitation intensity"@en ;
    skos:prefLabel "Intensidad de precipitación"@es ;
    skos:altLabel "Rainfall rate"@en ;
    skos:altLabel "Tasa de lluvia"@es ;
    qudt:applicableUnit unit:MilliM-PER-HR .

edintkos-vars:SnowDepth a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PrecipitationVariables ;
    skos:prefLabel "Snow depth"@en ;
    skos:prefLabel "Espesor de nieve"@es ;
    qudt:applicableUnit unit:CentiM .

edintkos-vars:SnowWaterEquivalent a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:PrecipitationVariables ;
    skos:prefLabel "Snow water equivalent"@en ;
    skos:prefLabel "Equivalente de agua de nieve"@es ;
    qudt:applicableUnit unit:MilliM .

# ---------------------------------------------------------------------------
# Radiation Variables
# ---------------------------------------------------------------------------

edintkos-vars:RadiationVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Radiation variables"@en ;
    skos:prefLabel "Variables de radiación"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:SolarIrradiance ;
    skos:narrower edintkos-vars:UVIndex ;
    skos:narrower edintkos-vars:PhotosyntheticallyActiveRadiation ;
    skos:narrower edintkos-vars:NetRadiation .

edintkos-vars:SolarIrradiance a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:RadiationVariables ;
    skos:prefLabel "Solar irradiance"@en ;
    skos:prefLabel "Irradiancia solar"@es ;
    skos:altLabel "Global solar radiation"@en ;
    skos:altLabel "Radiación solar global"@es ;
    qudt:applicableUnit unit:W-PER-M2 .

edintkos-vars:UVIndex a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:RadiationVariables ;
    skos:prefLabel "UV index"@en ;
    skos:prefLabel "Índice UV"@es ;
    qudt:applicableUnit unit:UNITLESS .

edintkos-vars:PhotosyntheticallyActiveRadiation a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:RadiationVariables ;
    skos:prefLabel "Photosynthetically active radiation"@en ;
    skos:prefLabel "Radiación fotosintéticamente activa"@es ;
    skos:altLabel "PAR"@en ;
    qudt:applicableUnit unit:MicroMOL-PER-M2-SEC .

edintkos-vars:NetRadiation a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:RadiationVariables ;
    skos:prefLabel "Net radiation"@en ;
    skos:prefLabel "Radiación neta"@es ;
    qudt:applicableUnit unit:W-PER-M2 .

# ---------------------------------------------------------------------------
# Light Variables
# ---------------------------------------------------------------------------

edintkos-vars:LightVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Light variables"@en ;
    skos:prefLabel "Variables de luz"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:Illuminance ;
    skos:narrower edintkos-vars:SunshineDuration .

edintkos-vars:Illuminance a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:LightVariables ;
    skos:prefLabel "Illuminance"@en ;
    skos:prefLabel "Iluminancia"@es ;
    skos:altLabel "Ambient light level"@en ;
    skos:altLabel "Nivel de luz ambiental"@es ;
    qudt:applicableUnit unit:LUX .

edintkos-vars:SunshineDuration a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:LightVariables ;
    skos:prefLabel "Sunshine duration"@en ;
    skos:prefLabel "Duración de la insolación"@es ;
    qudt:applicableUnit unit:HR .

# ---------------------------------------------------------------------------
# Visibility Variables
# ---------------------------------------------------------------------------

edintkos-vars:VisibilityVariables a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Visibility variables"@en ;
    skos:prefLabel "Variables de visibilidad"@es ;
    skos:broader edintkos-vars:MeteorologicalVariables ;
    skos:narrower edintkos-vars:Visibility ;
    skos:narrower edintkos-vars:CloudBaseHeight .

edintkos-vars:Visibility a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:VisibilityVariables ;
    skos:prefLabel "Visibility"@en ;
    skos:prefLabel "Visibilidad"@es ;
    skos:altLabel "Horizontal visibility"@en ;
    skos:altLabel "Visibilidad horizontal"@es ;
    qudt:applicableUnit unit:KiloM .

edintkos-vars:CloudBaseHeight a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:VisibilityVariables ;
    skos:prefLabel "Cloud base height"@en ;
    skos:prefLabel "Altura de la base de nubes"@es ;
    qudt:applicableUnit unit:M .

# ===========================================================================
# AIR QUALITY VARIABLES
# ===========================================================================

# ---------------------------------------------------------------------------
# Gaseous Pollutants
# ---------------------------------------------------------------------------

edintkos-vars:GaseousPollutants a skos:Concept ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Gaseous pollutants"@en ;
    skos:prefLabel "Contaminantes gaseosos"@es ;
    skos:broader edintkos-vars:AirQualityVariables ;
    skos:narrower edintkos-vars:NO2Concentration ;
    skos:narrower edintkos-vars:NOConcentration ;
    skos:narrower edintkos-vars:NOxConcentration ;
    skos:narrower edintkos-vars:O3Concentration ;
    skos:narrower edintkos-vars:SO2Concentration ;
    skos:narrower edintkos-vars:COConcentration ;
    skos:narrower edintkos-vars:NH3Concentration ;
    skos:narrower edintkos-vars:H2SConcentration .

edintkos-vars:NO2Concentration a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:broader edintkos-vars:GaseousPollutants ;
    skos:prefLabel "Nitrogen dioxide concentration"@en ;
    skos:prefLabel "Concentración de dióxido de nitrógeno"@es ;
    skos:altLabel "NO2"@en ;
    qudt:applicableUnit unit:MicroGM-PER-M3 .

