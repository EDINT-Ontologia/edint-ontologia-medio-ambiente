# ---------------------------------------------------------------------------
# CALIDAD DEL AGUA
# ---------------------------------------------------------------------------

edintkos-vars:ResidualFreeChlorine a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Residual free chlorine concentration in water"@en ;
    skos:prefLabel "Concentración de cloro libre residual en agua"@es ;
    skos:altLabel "Free chlorine"@en ;
    skos:altLabel "Cloro libre"@es ;
    qudt:applicableUnit unit:MilliGM-PER-L .

edintkos-vars:WaterTurbidity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Water turbidity"@en ;
    skos:prefLabel "Turbidez del agua"@es ;
    qudt:applicableUnit unit:NTU .

edintkos-vars:WaterPH a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Water hydrogen potential"@en ;
    skos:prefLabel "Potencial de hidrógeno en agua"@es ;
    skos:altLabel "pH"@en ;
    skos:altLabel "pH"@es ;
    qudt:applicableUnit unit:PH .

edintkos-vars:WaterElectricalConductivity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Water electrical conductivity"@en ;
    skos:prefLabel "Conductividad eléctrica del agua"@es ;
    qudt:applicableUnit unit:MicroS-PER-CentiM .

edintkos-vars:DissolvedOxygen a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Dissolved oxygen concentration in water"@en ;
    skos:prefLabel "Concentración de oxígeno disuelto en agua"@es ;
    skos:altLabel "Dissolved oxygen"@en ;
    skos:altLabel "Oxígeno disuelto"@es ;
    qudt:applicableUnit unit:MilliGM-PER-L .

edintkos-vars:WaterTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Water temperature"@en ;
    skos:prefLabel "Temperatura del agua"@es ;
    qudt:applicableUnit unit:DEG_C .

# ---------------------------------------------------------------------------
# ESTADO DEL SENSOR
# ---------------------------------------------------------------------------

edintkos-vars:BatteryLevel a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "IoT sensor battery level"@en ;
