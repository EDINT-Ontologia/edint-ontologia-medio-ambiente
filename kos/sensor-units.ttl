@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sosa: <http://www.w3.org/ns/sosa/> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix unit: <http://qudt.org/vocab/unit/> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ---------------------------------------------------------------------------
# ESQUEMA PRINCIPAL (Concept Scheme)
# ---------------------------------------------------------------------------
edintkos:SensorVariables a skos:ConceptScheme ;
    dct:issued "2026-03-18"^^xsd:date ;
    dct:modified "2026-03-18"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Sensor variables"@en ;
    rdfs:label "Variables de sensor"@es ;
    dct:title "Concept scheme grouping properties and magnitudes measured by sensors"@en ;
    dct:title "Esquema de conceptos agrupando magnitudes medidas por sensores"@es ;
    skos:note "Vocabulary of physical, chemical, and acoustic properties observable by sensors and their associated QUDT units."@en ;
    skos:note "Vocabulario de las diferentes magnitudes o propiedades físicas, químicas y acústicas observables mediante sensores y sus unidades QUDT asociadas."@es .

# ---------------------------------------------------------------------------
# METEOROLOGÍA Y FÍSICA
# ---------------------------------------------------------------------------

edintkos:AirTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Air temperature"@en ;
    skos:prefLabel "Temperatura del aire"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos:SoilTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Soil temperature"@en ;
    skos:prefLabel "Temperatura del suelo"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos:RoadTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Road temperature"@en ;
    skos:prefLabel "Temperatura de la calzada"@es ;
    skos:altLabel "Asphalt temperature"@en ;
    skos:altLabel "Temperatura del asfalto"@es ;
    qudt:applicableUnit unit:DEG_C .

edintkos:RelativeHumidity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Relative humidity"@en ;
    skos:prefLabel "Humedad relativa"@es ;
    qudt:applicableUnit unit:PERCENT .

edintkos:SoilMoistureTension a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Soil moisture tension"@en ;
    skos:prefLabel "Tensión de humedad del suelo"@es ;
    qudt:applicableUnit unit:KiloPA .

edintkos:AtmosphericPressure a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Atmospheric pressure"@en ;
    skos:prefLabel "Presión atmosférica"@es ;
    qudt:applicableUnit unit:HectoPA .

edintkos:WindSpeed a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Wind speed"@en ;
    skos:prefLabel "Velocidad del viento"@es ;
    qudt:applicableUnit unit:M-PER-SEC .

edintkos:MaximumWindSpeed a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Maximum wind speed"@en ;
    skos:prefLabel "Velocidad máxima del viento"@es ;
    skos:altLabel "Wind gust"@en ;
    skos:altLabel "Racha máxima de viento"@es ;
    qudt:applicableUnit unit:M-PER-SEC .

edintkos:WindDirection a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Wind direction"@en ;
    skos:prefLabel "Dirección del viento"@es ;
    qudt:applicableUnit unit:DEG .

edintkos:Precipitation a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Precipitation"@en ;
    skos:prefLabel "Precipitación"@es ;
    skos:altLabel "Rain"@en ;
    skos:altLabel "Lluvia"@es ;
    qudt:applicableUnit unit:MilliM , 
                        unit:L-PER-M2 .

edintkos:SolarRadiation a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Solar radiation"@en ;
    skos:prefLabel "Radiación solar"@es ;
    qudt:applicableUnit unit:W-PER-M2 .

edintkos:UVIndex a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "UV index"@en ;
    skos:prefLabel "Índice UV"@es ;
    skos:altLabel "Ultraviolet radiation"@en ;
    skos:altLabel "Radiación ultravioleta"@es ;
    qudt:applicableUnit unit:UNITLESS .

edintkos:PhotosyntheticallyActiveRadiation a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Photosynthetically active radiation"@en ;
    skos:prefLabel "Radiación fotosintéticamente activa"@es ;
    skos:altLabel "PAR"@en ;
    skos:altLabel "Radiación PAR"@es ;
    qudt:applicableUnit unit:MicroMOL-PER-M2-SEC .

edintkos:Illuminance a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Illuminance"@en ;
    skos:prefLabel "Iluminancia"@es ;
    skos:altLabel "Ambient street lighting"@en ;
    skos:altLabel "Luz ambiental en vía pública"@es ;
    qudt:applicableUnit unit:LUX .

