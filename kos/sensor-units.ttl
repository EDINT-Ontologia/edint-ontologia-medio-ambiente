    skos:prefLabel "Concentración de monóxido de carbono"@es ;
    skos:altLabel "CO"@en ;
    skos:altLabel "CO"@es ;
    qudt:applicableUnit unit:MilliGM-PER-M3 .

edintkos-vars:NH3Concentration a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
