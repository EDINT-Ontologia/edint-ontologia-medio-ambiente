# ---------------------------------------------------------------------------
# CALIDAD DEL AGUA
# ---------------------------------------------------------------------------

edintkos:WaterSupplyFlowRate a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Water supply flow rate"@en ;
    skos:prefLabel "Caudal de red de abastecimiento"@es ;
    skos:altLabel "Water flow rate"@en ;
    skos:altLabel "Caudal de agua"@es ;
    qudt:applicableUnit unit:L-PER-SEC .

edintkos:ResidualFreeChlorine a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Residual free chlorine in water"@en ;
    skos:prefLabel "Cloro libre residual en agua"@es ;
    skos:altLabel "Free chlorine"@en ;
    skos:altLabel "Cloro libre"@es ;
    qudt:applicableUnit unit:MilliGM-PER-L .

edintkos:WaterTurbidity a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Water turbidity"@en ;
    skos:prefLabel "Turbidez del agua"@es ;
    qudt:applicableUnit unit:NTU .

edintkos:WaterPH a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Water hydrogen potential"@en ;
    skos:prefLabel "Potencial de hidrógeno en agua"@es ;
    skos:altLabel "pH"@en ;
    skos:altLabel "pH"@es ;
