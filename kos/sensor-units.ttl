    skos:prefLabel "Dissolved oxygen in water"@en ;
    skos:prefLabel "Oxígeno disuelto en agua"@es ;
    skos:altLabel "Dissolved oxygen"@en ;
    skos:altLabel "Oxígeno disuelto"@es ;
    qudt:applicableUnit unit:MilliGM-PER-L .

edintkos:WaterTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Water temperature"@en ;
    skos:prefLabel "Temperatura del agua"@es ;
    qudt:applicableUnit unit:DEG_C .

