    skos:prefLabel "Battery voltage"@en ;
    skos:prefLabel "Voltaje de batería"@es ;
    qudt:applicableUnit unit:V .

edintkos-vars:InternalSensorTemperature a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos-vars:SensorVariables ;
    skos:prefLabel "Internal sensor temperature"@en ;
    skos:prefLabel "Temperatura interna del sensor"@es ;
