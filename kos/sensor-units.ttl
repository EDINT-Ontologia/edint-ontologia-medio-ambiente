# ESTADO DEL SENSOR
# ---------------------------------------------------------------------------

edintkos:BatteryLevel a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "IoT sensor battery level"@en ;
    skos:prefLabel "Nivel de batería del sensor IoT"@es ;
    skos:altLabel "Battery level"@en ;
    skos:altLabel "Nivel de batería"@es ;
    qudt:applicableUnit unit:PERCENT .

edintkos:BatteryVoltage a skos:Concept, sosa:ObservableProperty, qudt:QuantityKind ;
    skos:inScheme edintkos:SensorVariables ;
    skos:prefLabel "Battery voltage"@en ;
    skos:prefLabel "Voltaje de batería"@es ;
